# AI concierge (Python). Build from the repo root:
#   docker build -f infra/docker/Dockerfile.ai -t xenia-ai services/ai-concierge
FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY . .
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
