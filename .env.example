# ============================================================================
# Xenia environment template. Copy to .env and fill in. Never commit .env.
# ============================================================================

NODE_ENV=development

# --- Datastores (match infra/compose/docker-compose.yml) ---
# The app connects as the NON-superuser role (RLS is enforced for it).
DATABASE_URL=postgres://xenia_app:xenia_app@localhost:5442/xenia
# Migrations/seed connect as the privileged role (creates extensions/roles/RLS).
DATABASE_ADMIN_URL=postgres://xenia:xenia@localhost:5442/xenia
REDIS_URL=redis://localhost:6399

# --- Core API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
JWT_SECRET=change-me-in-prod-use-a-32-byte-random-string
MAGIC_LINK_SECRET=change-me-too
# Auth token lifetimes (sensible defaults applied if unset)
JWT_ACCESS_TTL=15m
JWT_MAGIC_TTL=2h
JWT_REFRESH_TTL_DAYS=30

# --- Web dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- AI Concierge service ---
AI_CONCIERGE_PORT=8000
AI_CONCIERGE_URL=http://localhost:8000
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Reasoning/agent model + cheap high-volume model (see services/ai-concierge/app/config.py)
ANTHROPIC_AGENT_MODEL=claude-opus-4-8
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
# Embeddings (Voyage AI — Anthropic's recommended embedding provider; no local torch needed)
VOYAGE_API_KEY=pa-xxxxxxxx
VOYAGE_EMBED_MODEL=voyage-3
EMBED_DIM=1024

# --- Workers ---
WORKERS_CONCURRENCY=8

# --- Notifications (providers; leave blank to use the simulated provider) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM=
SMTP_URL=

# --- Smart locks ---
# LOCK_PROVIDER=simulator | seam
LOCK_PROVIDER=simulator
SEAM_API_KEY=

# --- Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=xenia
